# .env.example
# 이 파일을 복사해서 .env 로 저장한 뒤, 각 값을 채워 주세요.
#   cp .env.example .env
# .env 는 절대 git 에 커밋하지 마세요 (이미 .gitignore 에 등록됨).

# ─── 블로그 도메인 ───────────────────────────────────────────────
# Cloudflare Tunnel 에 등록한 퍼블릭 호스트명.
# 한글 도메인은 퓨니코드(xn--...) 형태로 적어야 합니다.
#   광주복싱.com  →  xn--oy2b35ckwh3a.com
BLOG_DOMAIN=blog.xn--oy2b35ckwh3a.com

# ─── MySQL 자격증명 ──────────────────────────────────────────────
# 두 비밀번호 모두 충분히 길고 임의로 생성된 값을 사용하세요.
#   예: openssl rand -base64 32
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_PASSWORD=change-me-wp
MYSQL_DATABASE=wordpress
MYSQL_USER=wordpress
WORDPRESS_TABLE_PREFIX=wp_

# ─── Cloudflare Tunnel 토큰 ──────────────────────────────────────
# Cloudflare Zero Trust → Networks → Tunnels → Create a tunnel
# 에서 발급받는 긴 문자열. README 의 "Cloudflare Tunnel 설정" 참고.
CLOUDFLARE_TUNNEL_TOKEN=eyJhIjoi...paste-token-here
